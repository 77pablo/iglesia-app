# Copia este archivo a backend/.env y rellena los valores (NO subas .env a git).
# En produccion (Railway) define estas variables en el panel del proyecto.
# Este archivo documenta SOLO los nombres, sin valores reales.

# --- REQUERIDA en produccion (NODE_ENV=production) ---
# Secreto para firmar/verificar los JWT de sesion. Sin ella la app NO
# arranca en produccion (ver backend/src/auth.js). En desarrollo tiene
# un valor por defecto solo para pruebas locales.
JWT_SECRET=

# --- Entorno ---
# "production" activa las validaciones estrictas (JWT_SECRET obligatorio,
# etc). Dejar vacio o "development" en local.
NODE_ENV=

# --- Web Push (VAPID) — opcional: si faltan, el push real se desactiva ---
# --- y la app degrada con elegancia (las notificaciones siguen in-app) ---
# Genera un par con:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=

# --- Base de datos y archivos ---
# Ruta del archivo SQLite. Si no se define, usa backend/iglesia.db
DB_PATH=
# Carpeta donde se guardan los archivos subidos (/api/upload). Si no
# se define, usa backend/uploads
UPLOADS_DIR=

# --- Servidor ---
# Puerto donde escucha la API. Por defecto 3000.
PORT=
# Origenes permitidos por CORS, separados por coma (ej: https://miapp.com).
# Si no se define, se permite cualquier origen (solo recomendado en dev).
CORS_ORIGIN=

# --- Datos de demo ---
# Si es "1" y la base de datos esta vacia, siembra datos de prueba al
# arrancar (ver backend/src/seed.js). NO usar en produccion real.
SEED_ON_EMPTY=

# ------------------------------------------------------------
# Otras variables opcionales usadas por modulos concretos (no forman
# parte del set minimo pedido, pero existen en el codigo):
# ------------------------------------------------------------

# Correo (Gmail SMTP) para recuperar contrasena por codigo:
#   SMTP_USER = tu correo @gmail.com
#   SMTP_PASS = "Contrasena de aplicacion" de Google (16 letras, NO la normal)
#   SMTP_FROM = (opcional) remitente visible
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Reconocimiento facial (servicio Python externo, opcional)
FACIAL_PY_URL=
FACIAL_UMBRAL=
