# Copia este archivo a backend/.env y rellena los valores (NO subas .env a git).
# En produccion (Railway) define estas variables en el panel del proyecto.

# Web Push (VAPID). Genera un par con:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:tu-correo@ejemplo.com

# Correo (Gmail SMTP) para recuperar contrasena por codigo:
#   SMTP_USER = tu correo @gmail.com
#   SMTP_PASS = "Contrasena de aplicacion" de Google (16 letras, NO la normal)
#   SMTP_FROM = (opcional) remitente visible
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# (Opcional) otras variables que el backend ya entiende:
# JWT_SECRET=...
# DB_PATH=/data/iglesia.db
# UPLOADS_DIR=/data/uploads
# SEED_ON_EMPTY=1
# CORS_ORIGIN=https://tu-dominio
# PORT=3000
